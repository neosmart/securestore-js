{
  "name": "@neosmart/securestore",
  "version": "1.0.0",
  "type": "module",
  "files": [
      "dist/SecureStore*.js",
      "dist/SecureStore*.d.ts"
  ],
  "exports": {
    ".": {
      "node": {
        "types": "./dist/SecureStoreExt.d.ts",
        "import": "./dist/SecureStoreExt.js"
      },
      "default": {
        "types": "./dist/SecureStore.d.ts",
        "import": "./dist/SecureStore.js"
      }
    }
  },
  "keywords": [
    "SecureStore",
    "encryption",
    "secrets"
  ],
  "homepage": "https://neosmart.net/SecureStore/",
  "bugs": "https://github.com/neosmart/securestore-js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neosmart/securestore-js.git"
  },
  "license": "MIT",
  "author": {
    "name": "Mahmoud Al-Qudsi",
    "email": "mqudsi@neosmart.net",
    "url": "https://github.com/mqudsi"
  },
  "funding": "https://mqudsi.com/donate/",
  "scripts": {
    "prepublishOnly": "npm run clean && npm run build",
    "clean": "node -e \"['README.pdf', 'README.html'].forEach(f => require('fs').rmSync(f, { force: true }))\"",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^6"
  },
  "peerDependencies": {
    "@neosmart/ssclient": "^2.0.0"
  }
}
